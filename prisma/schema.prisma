generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  salaries     Salary[]
}

model Company {
  id             String   @id @default(cuid())
  name           String   @unique
  normalizedName String   @unique
  logoUrl        String?
  industry       String?
  website        String?
  createdAt      DateTime @default(now())
  salaries       Salary[]
}

model Salary {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  jobTitle        String
  level           String
  levelOrder      Int
  baseSalary      Float
  bonus           Float    @default(0)
  stockPerYear    Float    @default(0)
  totalComp       Float
  currency        String   @default("INR")
  location        String
  city            String
  country         String   @default("India")
  yearsExperience Int
  yearsAtCompany  Int      @default(0)
  education       String?
  department      String?
  verified        Boolean  @default(false)
  submittedAt     DateTime @default(now())
  tags            String[]

  @@index([companyId])
  @@index([level])
  @@index([location])
  @@index([totalComp])
}